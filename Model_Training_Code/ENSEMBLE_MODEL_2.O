n","plt.title(\"Stacking Ensemble\")\n","\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":387},"id":"3rxe6h2jOae8","executionInfo":{"status":"ok","timestamp":1782499106963,"user_tz":-330,"elapsed":267,"user":{"displayName":"MADHURI KUMARI","userId":"10034460224407763621"}},"outputId":"bf95d378-9c41-4a38-c2fb-e69caa1faaa7"},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1500x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["ensemble[\"Volatility\"] = (\n","\n","    ensemble[\"Actual\"]\n","\n","    .pct_change()\n","\n","    .rolling(20)\n","\n","    .std()\n","\n",")"],"metadata":{"id":"cMkgPYHqOe_e"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["threshold = ensemble[\"Volatility\"].median()\n","\n","print(threshold)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"pD4TPLYUOi5S","executionInfo":{"status":"ok","timestamp":1782499137106,"user_tz":-330,"elapsed":63,"user":{"displayName":"MADHURI KUMARI","userId":"10034460224407763621"}},"outputId":"142c6eff-cfe0-483e-fe5e-27ba51756cbd"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["0.017016264080865363\n"]}]},{"cell_type":"code","source":["ensemble[\"Regime\"] = np.where(\n","\n","    ensemble[\"Volatility\"] > threshold,\n","\n","    \"High\",\n","\n","    \"Low\"\n","\n",")"],"metadata":{"id":"AfT_cVfvOmE4"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["dynamic_predictions = []\n","\n","for i in range(len(ensemble)):\n","\n","    if ensemble.iloc[i][\"Regime\"]==\"High\":\n","\n","        pred = (\n","\n","            0.15*ensemble.iloc[i][\"ARIMA\"]\n","\n","            +\n","\n","            0.15*ensemble.iloc[i][\"Prophet\"]\n","\n","            +\n","\n","            0.35*ensemble.iloc[i][\"LSTM\"]\n","\n","            +\n","\n","            0.35*ensemble.iloc[i][\"XGBoost\"]\n","\n","        )\n","\n","    else:\n","\n","        pred = (\n","\n","            0.35*ensemble.iloc[i][\"ARIMA\"]\n","\n","            +\n","\n","            0.35*ensemble.iloc[i][\"Prophet\"]\n","\n","            +\n","\n","            0.15*ensemble.iloc[i][\"LSTM\"]\n","\n","            +\n","\n","            0.15*ensemble.iloc[i][\"XGBoost\"]\n","\n","        )\n","\n","    dynamic_predictions.append(pred)\n","\n","ensemble[\"Dynamic_Ensemble\"] = dynamic_predictions"],"metadata":{"id":"qQgFhY7-Orgi"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["rmse_dynamic = np.sqrt(\n","\n","    mean_squared_error(\n","\n","        ensemble[\"Actual\"],\n","\n","        ensemble[\"Dynamic_Ensemble\"]\n","\n","    )\n","\n",")\n","\n","mae_dynamic = mean_absolute_error(\n","\n","    ensemble[\"Actual\"],\n","\n","    ensemble[\"Dynamic_Ensemble\"]\n","\n",")\n","\n","mape_dynamic = np.mean(\n","\n","    np.abs(\n","\n","        (\n","\n","            ensemble[\"Actual\"]\n","\n","            -\n","\n","            ensemble[\"Dynamic_Ensemble\"]\n","\n","        )\n","\n","        /\n","\n","        ensemble[\"Actual\"]\n","\n","    )\n","\n",")*100\n","\n","r2_dynamic = r2_score(\n","\n","    ensemble[\"Actual\"],\n","\n","    ensemble[\"Dynamic_Ensemble\"]\n","\n",")\n","\n","print(\"Dynamic Ensemble\")\n","\n","print(\"----------------\")\n","\n","print(\"RMSE :\",rmse_dynamic)\n","\n","print(\"MAE :\",mae_dynamic)\n","\n","print(\"MAPE :\",mape_dynamic)\n","\n","print(\"R2 :\",r2_dynamic)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"0ko585xSOvTh","executionInfo":{"status":"ok","timestamp":1782499195239,"user_tz":-330,"elapsed":68,"user":{"displayName":"MADHURI KUMARI","userId":"10034460224407763621"}},"outputId":"8b9beb1c-0555-4dc9-a3b7-100d683c844d"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Dynamic Ensemble\n","----------------\n","RMSE : 9.933419971687755\n","MAE : 9.659839093169692\n","MAPE : 29.12069827433847\n","R2 : -22.552548389714005\n"]}]},{"cell_type":"code","source":["plt.figure(figsize=(15,6))\n","\n","plt.plot(\n","\n","    ensemble[\"Actual\"],\n","\n","    label=\"Actual\"\n","\n",")\n","\n","plt.plot(\n","\n","    ensemble[\"Dynamic_Ensemble\"],\n","\n","    label=\"Dynamic Ensemble\"\n","\n",")\n","\n","plt.legend()\n","\n","plt.title(\"Dynamic Regime Ensemble\")\n","\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":383},"id":"1kxv8ouLO0Rf","executionInfo":{"status":"ok","timestamp":1782499211703,"user_tz":-330,"elapsed":446,"user":{"displayName":"MADHURI KUMARI","userId":"10034460224407763621"}},"outputId":"28f0b09d-f06c-4a92-b8f2-7a95efea8def"},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1500x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["ensemble.to_csv(\n","\n","    \"ensemble_complete_predictions.csv\",\n","\n","    index=False\n","\n",")\n","\n","print(\"Saved Successfully\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"oNcLiN2_O4ca","executionInfo":{"status":"ok","timestamp":1782499227211,"user_tz":-330,"elapsed":67,"user":{"displayName":"MADHURI KUMARI","userId":"10034460224407763621"}},"outputId":"e32987f0-9221-4759-8140-c554b9cbd4a4"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Saved Successfully\n"]}]},{"cell_type":"code","source":["import numpy as np\n","import pandas as pd\n","import matplotlib.pyplot as plt\n","\n","from sklearn.metrics import (\n","    mean_squared_error,\n","    mean_absolute_error,\n","    r2_score\n",")"],"metadata":{"id":"rcavNVHHO-JQ"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["ensemble.loc[\n","    X_test_meta.index,\n","    \"Stacking\"\n","] = stack_predictions"],"metadata":{"id":"ny3Ff2FnPgqW"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["ensemble[\"Stacking\"] = ensemble[\"Stacking\"].fillna(\n","    ensemble[\"Weighted_Ensemble\"]\n",")"],"metadata":{"id":"tlrY4znEPkCS"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["models = [\n","\n","    \"ARIMA\",\n","\n","    \"Prophet\",\n","\n","    \"LSTM\",\n","\n","    \"XGBoost\",\n","\n","    \"Simple_Average\",\n","\n","    \"Weighted_Ensemble\",\n","\n","    \"Stacking\",\n","\n","    \"Dynamic_Ensemble\"\n","\n","]"],"metadata":{"id":"FTpuInFaPntZ"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["def evaluate_model(actual, prediction):\n","\n","    rmse = np.sqrt(\n","\n","        mean_squared_error(\n","\n","            actual,\n","\n","            prediction\n","\n","        )\n","\n","    )\n","\n","    mae = mean_absolute_error(\n","\n","        actual,\n","\n","        prediction\n","\n","    )\n","\n","    mape = np.mean(\n","\n","        np.abs(\n","\n","            (actual-prediction)\n","\n","            /\n","\n","            actual\n","\n","        )\n","\n","    )*100\n","\n","    r2 = r2_score(\n","\n","        actual,\n","\n","        prediction\n","\n","    )\n","\n","    return rmse,mae,mape,r2"],"metadata":{"id":"bPLaVwTVPrEh"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["def directional_accuracy(actual,prediction):\n","\n","    actual_direction = np.sign(\n","\n","        actual.diff()\n","\n","    )\n","\n","    pred_direction = np.sign(\n","\n","        prediction.diff()\n","\n","    )\n","\n","    return (\n","\n","        actual_direction\n","\n","        ==\n","\n","        pred_direction\n","\n","    ).mean()*100"],"metadata":{"id":"9S_VBfzfPuxC"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["results = []\n","\n","for model in models:\n","\n","    rmse,mae,mape,r2 = evaluate_model(\n","\n","        ensemble[\"Actual\"],\n","\n","        ensemble[model]\n","\n","    )\n","\n","    direction = directional_accuracy(\n","\n","        ensemble[\"Actual\"],\n","\n","        ensemble