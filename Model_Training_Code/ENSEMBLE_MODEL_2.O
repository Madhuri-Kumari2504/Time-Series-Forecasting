emble[\"Strategy_Cumulative\"]\n","\n","    -\n","\n","    rolling_max\n","\n",")\n","\n","/\n","\n","rolling_max\n","\n","max_drawdown = drawdown.min()\n","\n","print(\"Maximum Drawdown\")\n","\n","print(max_drawdown)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"UkFQwNErRF3Q","executionInfo":{"status":"ok","timestamp":1782499805064,"user_tz":-330,"elapsed":56,"user":{"displayName":"MADHURI KUMARI","userId":"10034460224407763621"}},"outputId":"8473cd35-f4c4-4145-d39e-231aa23f947b"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Maximum Drawdown\n","-0.11880333785426878\n"]}]},{"cell_type":"code","source":["wins = (\n","\n","    ensemble[\"Strategy_Return\"] > 0\n","\n",").sum()\n","\n","total = len(\n","\n","    ensemble[\"Strategy_Return\"]\n","\n",")\n","\n","win_rate = wins/total*100\n","\n","print(\"Win Rate\")\n","\n","print(win_rate)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"Y3K8MwgjRJHU","executionInfo":{"status":"ok","timestamp":1782499826554,"user_tz":-330,"elapsed":63,"user":{"displayName":"MADHURI KUMARI","userId":"10034460224407763621"}},"outputId":"74163021-e141-45a9-f34b-8c5161ce79ed"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Win Rate\n","11.884057971014492\n"]}]},{"cell_type":"code","source":["market_return = (\n","\n","    ensemble[\"Market_Cumulative\"]\n","\n","    .iloc[-1]\n","\n","    -\n","\n","    1\n","\n",")*100\n","\n","strategy_return = (\n","\n","    ensemble[\"Strategy_Cumulative\"]\n","\n","    .iloc[-1]\n","\n","    -\n","\n","    1\n","\n",")*100\n","\n","print(\"Market Return\")\n","\n","print(market_return)\n","\n","print()\n","\n","print(\"Strategy Return\")\n","\n","print(strategy_return)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"W6tUtiydROVK","executionInfo":{"status":"ok","timestamp":1782499840300,"user_tz":-330,"elapsed":33,"user":{"displayName":"MADHURI KUMARI","userId":"10034460224407763621"}},"outputId":"b7c8e09e-29cb-4c2c-8195-30ca6df6af74"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Market Return\n","16.089300911662964\n","\n","Strategy Return\n","0.22030113446416255\n"]}]},{"cell_type":"code","source":["buy = (\n","\n","    ensemble[\"Signal\"]==1\n","\n",").sum()\n","\n","sell = (\n","\n","    ensemble[\"Signal\"]==-1\n","\n",").sum()\n","\n","hold = (\n","\n","    ensemble[\"Signal\"]==0\n","\n",").sum()\n","\n","print(\"BUY :\",buy)\n","\n","print(\"SELL :\",sell)\n","\n","print(\"HOLD :\",hold)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"5e8gLeFVRRsR","executionInfo":{"status":"ok","timestamp":1782499858130,"user_tz":-330,"elapsed":49,"user":{"displayName":"MADHURI KUMARI","userId":"10034460224407763621"}},"outputId":"131082a1-04ed-4c73-eedf-b558ce2d02aa"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["BUY : 35\n","SELL : 43\n","HOLD : 267\n"]}]},{"cell_type":"code","source":["plt.figure(figsize=(15,6))\n","\n","plt.plot(\n","\n","    ensemble[\"Actual\"],\n","\n","    label=\"Price\"\n","\n",")\n","\n","buy_points = ensemble[\n","    ensemble[\"Signal\"]==1\n","]\n","\n","sell_points = ensemble[\n","    ensemble[\"Signal\"]==-1\n","]\n","\n","plt.scatter(\n","\n","    buy_points.index,\n","\n","    buy_points[\"Actual\"],\n","\n","    marker=\"^\",\n","\n","    s=80,\n","\n","    label=\"BUY\"\n","\n",")\n","\n","plt.scatter(\n","\n","    sell_points.index,\n","\n","    sell_points[\"Actual\"],\n","\n","    marker=\"v\",\n","\n","    s=80,\n","\n","    label=\"SELL\"\n","\n",")\n","\n","plt.legend()\n","\n","plt.title(\"Trading Signals\")\n","\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":387},"id":"SfWhVkARRWFw","executionInfo":{"status":"ok","timestamp":1782499873773,"user_tz":-330,"elapsed":1318,"user":{"displayName":"MADHURI KUMARI","userId":"10034460224407763621"}},"outputId":"e794dd2a-b62b-